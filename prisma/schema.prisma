generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int        @id @default(autoincrement())
  password             String?
  createdAt            DateTime   @default(now())
  email                String?    @unique
  isVerified           Boolean    @default(false)
  mobileNumber         String     @unique
  name                 String?
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  updatedAt            DateTime   @updatedAt
  cart                 Cart?
  orders               Order[]
  wishlist             Wishlist[]

  @@index([mobileNumber])
  @@index([email])
}

model GlobalConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerOnboarding {
  id              Int              @id @default(autoincrement())
  phone           String           @unique
  stepCompleted   Int              @default(0)
  basicDetails    Json?
  businessDetails Json?
  bankDetails     Json?
  status          OnboardingStatus @default(PENDING_APPROVAL)
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([phone])
  @@index([status])
}

model Seller {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  mobile          String           @unique
  password        String
  sellerType      SellerType
  sellerStatus    SellerStatus     @default(PENDING)
  rejectionReason String?
  refreshToken    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  addresses       Address[]
  bankDetails     BankDetails?
  businessDetails BusinessDetails?
  catalogs        Catalog[]

  @@index([mobile])
  @@index([email])
  @@index([sellerStatus])
}

model OTP {
  id           Int      @id @default(autoincrement())
  mobileNumber String
  role         String
  requestId    String
  codeHash     String?
  expiresAt    DateTime
  verified     Boolean  @default(false)
  used         Boolean  @default(false)
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([mobileNumber, role])
  @@index([requestId])
}

model BusinessDetails {
  id                Int      @id @default(autoincrement())
  sellerId          Int      @unique
  businessName      String
  ownerName         String
  productCategories String[]
  storeType         String?
  gstin             String?  @unique
  gstDocumentUrl    String?
  gstVerified       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  seller            Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([gstin])
}

model Address {
  id          Int         @id @default(autoincrement())
  sellerId    Int
  fullName    String
  phone       String
  pincode     String
  state       String
  city        String
  addressLine String
  landmark    String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean     @default(true)
  type        AddressType @default(PICKUP)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  seller      Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model BankDetails {
  id                     Int      @id @default(autoincrement())
  sellerId               Int      @unique
  accountHolderName      String
  accountNumberEncrypted String
  ifsc                   String
  bankName               String
  branch                 String
  verified               Boolean  @default(false)
  verificationRef        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  seller                 Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Category {
  id              Int                      @id @default(autoincrement())
  name            String
  slug            String                   @unique
  parentId        Int?
  isLeaf          Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  level           Int                      @default(1)
  catalogs        Catalog[]
  parent          Category?                @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[]               @relation("CategoryTree")
  attributes      CategoryAttribute[]
  attributeGroups CategoryAttributeGroup[]

  @@unique([name, parentId])
  @@index([parentId])
  @@index([isLeaf])
}

model CategoryAttributeGroup {
  id         Int                 @id @default(autoincrement())
  categoryId Int
  name       String
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  attributes CategoryAttribute[]
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model CategoryAttribute {
  id               Int                     @id @default(autoincrement())
  categoryId       Int
  groupId          Int?
  name             String
  type             AttributeType
  isRequired       Boolean                 @default(false)
  isVariant        Boolean                 @default(true)
  groupType        AttributeGroup          @default(PRODUCT_INVENTORY)
  createdAt        DateTime                @default(now())
  options          AttributeOption[]
  catalogValues    CatalogAttributeValue[]
  category         Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group            CategoryAttributeGroup? @relation(fields: [groupId], references: [id])
  values           ProductAttributeValue[]
  sizeTableColumns SizeTableColumn[]

  @@index([categoryId])
  @@index([groupId])
}

model AttributeOption {
  id          Int               @id @default(autoincrement())
  attributeId Int
  value       String
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([attributeId])
}

model SizeTableColumn {
  id          Int                     @id @default(autoincrement())
  attributeId Int
  name        String
  unit        String?
  inputType   String                  @default("SELECT")
  isRequired  Boolean                 @default(true)
  sortOrder   Int                     @default(0)
  createdAt   DateTime                @default(now())
  attribute   CategoryAttribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  options     SizeTableColumnOption[]

  @@index([attributeId])
}

model SizeTableColumnOption {
  id       Int             @id @default(autoincrement())
  columnId Int
  value    String
  column   SizeTableColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([columnId])
}

model CatalogAttributeValue {
  id          Int               @id @default(autoincrement())
  catalogId   Int
  attributeId Int
  value       String
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id])
  catalog     Catalog           @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, attributeId])
  @@index([catalogId])
}

model Catalog {
  id               Int                     @id @default(autoincrement())
  sellerId         Int
  categoryId       Int
  brandName        String?
  isReturnable     Boolean                 @default(true)
  isCodAllowed     Boolean                 @default(true)
  status           CatalogStatus           @default(DRAFT)
  rejectionNote    String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  documents        BrandDocument[]
  category         Category                @relation(fields: [categoryId], references: [id])
  seller           Seller                  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  commonAttributes CatalogAttributeValue[]
  products         Product[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
}

model Product {
  id              Int                     @id @default(autoincrement())
  catalogId       Int
  productName     String?
  price           Decimal                 @db.Decimal(10, 2)
  mrp             Decimal?                @db.Decimal(10, 2)
  returnPrice     Decimal?                @db.Decimal(10, 2)
  stock           Int
  sku             String
  hsn             String?
  gstRate         Decimal?                @db.Decimal(5, 2)
  netWeight       Decimal?                @db.Decimal(8, 3)
  styleCode       String?
  sizeDetails     Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  catalog         Catalog                 @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  attributeValues ProductAttributeValue[]
  images          ProductImage[]
  wishlistItems   Wishlist[]
  stockLogs       StockLog[]

  @@index([catalogId])
  @@index([sku])
}

model ProductAttributeValue {
  id          Int               @id @default(autoincrement())
  productId   Int
  attributeId Int
  value       String
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id])
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([productId])
}

model ProductImage {
  id        Int       @id @default(autoincrement())
  productId Int
  imageType ImageType
  url       String
  createdAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, imageType])
  @@index([productId])
}

model BrandDocument {
  id           Int          @id @default(autoincrement())
  catalogId    Int
  documentUrl  String
  documentType DocumentType
  createdAt    DateTime     @default(now())
  catalog      Catalog      @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int
  subTotal      Decimal     @db.Decimal(10, 2)
  totalGst      Decimal     @db.Decimal(10, 2)
  totalTcs      Decimal     @db.Decimal(10, 2)
  totalTds      Decimal     @db.Decimal(10, 2)
  totalDiscount Decimal     @db.Decimal(10, 2)
  grandTotal    Decimal     @db.Decimal(10, 2)
  totalCommission Decimal   @default(0) @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              Int             @id @default(autoincrement())
  orderId         Int
  productId       Int
  quantity        Int
  price           Decimal         @db.Decimal(10, 2)
  mrp             Decimal         @db.Decimal(10, 2)
  gstAmount       Decimal         @db.Decimal(10, 2)
  tcsAmount       Decimal         @db.Decimal(10, 2)
  tdsAmount       Decimal         @db.Decimal(10, 2)
  commissionRate  Decimal         @default(0) @db.Decimal(5, 2)
  commissionAmount Decimal        @default(0) @db.Decimal(10, 2)
  status          OrderItemStatus @default(PENDING)
  dispatchSla     DateTime?
  labelDownloaded Boolean         @default(false)
  deliveryPartner String?
  trackingId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

model StockLog {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldStock  Int
  newStock  Int
  change    Int
  reason    String // e.g., "ORDER_PLACED", "MANUAL_UPDATE", "ORDER_CANCELLED"
  orderId   Int?
  createdAt DateTime @default(now())

  @@index([productId])
}


enum OrderStatus {
  PENDING
  PLACED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  ON_HOLD
  PENDING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum SellerType {
  MANUFACTURER
  WHOLESALER
  TRADER
  RETAILER
}

enum OnboardingStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AddressType {
  PICKUP
  BILLING
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
}

enum CatalogStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  DISCARDED
  PAUSED
  BLOCKED
}

enum DocumentType {
  TRADEMARK
  AUTHORIZATION_LETTER
  INVOICE
  OTHER
}

enum AttributeGroup {
  PRODUCT_INVENTORY
  PRODUCT_DETAILS
  OTHER_ATTRIBUTES
}

enum ImageType {
  FRONT
  BACK
  SIDE
  ZOOMED
}
